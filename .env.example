# Database
# Railway: provided automatically by PostgreSQL addon
# Hetzner: uses DB_PASSWORD below
DB_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://cataclysm:${DB_PASSWORD}@postgres:5432/cataclysm

# Anthropic API (for AI coaching)
ANTHROPIC_API_KEY=sk-ant-your-key

# Auth (shared between frontend and backend)
NEXTAUTH_SECRET=generate-a-strong-secret
NEXTAUTH_URL=http://YOUR_VPS_IP

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# CORS (backend only — set to frontend URL)
CORS_ORIGINS=["http://YOUR_VPS_IP"]

# App
PORT=8000
AUTH_TRUST_HOST=true

# Grafana (Hetzner only)
GF_SECURITY_ADMIN_PASSWORD=changeme

# Caddy basic auth for monitoring endpoints (Hetzner only)
# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'YOUR_PASSWORD'
CADDY_ADMIN_USER=admin
CADDY_ADMIN_HASH=$2a$14$CHANGE_ME_GENERATE_WITH_CADDY_HASH_PASSWORD
