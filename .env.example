# =============================================================================
# Cataclysm Environment Variables — Hetzner VPS
# =============================================================================
# Copy to .env (prod) or .env.staging (staging) and fill in real values.
# NEVER commit .env files to git.

# -- Database ------------------------------------------------------------------
# Each env has its own Postgres container. Generate unique passwords.
DB_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# -- Auth ----------------------------------------------------------------------
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# Prod: https://cataclysm.one | Staging: https://staging.cataclysm.one
NEXTAUTH_URL=https://cataclysm.one

# -- Google OAuth --------------------------------------------------------------
# Console: https://console.cloud.google.com/apis/credentials
# Add redirect URIs for BOTH envs before first deploy:
#   https://cataclysm.one/api/auth/callback/google
#   https://staging.cataclysm.one/api/auth/callback/google
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# -- LLM (AI coaching) --------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key

# -- CORS ----------------------------------------------------------------------
# Must match the frontend URL. JSON array format.
# Prod: ["https://cataclysm.one"] | Staging: ["https://staging.cataclysm.one"]
CORS_ORIGINS=["https://cataclysm.one"]

# -- App -----------------------------------------------------------------------
PORT=8000
AUTH_TRUST_HOST=true
LLM_LAZY_GENERATION_ENABLED=true
STARTUP_REHYDRATION_LIMIT=20

# -- Monitoring (prod only, staging shares prod's Grafana) ---------------------
# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'YOUR_PASSWORD'
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME
CADDY_ADMIN_USER=admin
CADDY_ADMIN_HASH=CHANGE_ME_GENERATE_WITH_CADDY

# -- Mapbox (satellite maps) --------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token
