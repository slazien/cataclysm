{
    admin :2019
    servers {
        metrics
    }
}

# === Production ===
cataclysm.one {
    # API routes → prod backend
    handle /api/* {
        reverse_proxy prod_backend:8000
    }

    # Health check → prod backend
    handle /health {
        reverse_proxy prod_backend:8000
    }

    # Metrics (internal only)
    handle /metrics {
        respond "Forbidden" 403
    }

    # Grafana dashboard (basic auth)
    handle_path /grafana/* {
        basic_auth {
            {$CADDY_ADMIN_USER:admin} {$CADDY_ADMIN_HASH}
        }
        reverse_proxy grafana:3000
    }

    # Dozzle log viewer (basic auth)
    handle_path /dozzle/* {
        basic_auth {
            {$CADDY_ADMIN_USER:admin} {$CADDY_ADMIN_HASH}
        }
        reverse_proxy dozzle:8080
    }

    # Everything else → prod frontend
    handle {
        reverse_proxy prod_frontend:3000
    }
}

# === Staging ===
staging.cataclysm.one {
    handle /api/* {
        reverse_proxy staging_backend:8000
    }

    handle /health {
        reverse_proxy staging_backend:8000
    }

    handle /metrics {
        respond "Forbidden" 403
    }

    handle {
        reverse_proxy staging_frontend:3000
    }
}
