:80 {
    # API routes → backend
    handle /api/* {
        reverse_proxy backend:8000
    }

    # Health check → backend
    handle /health {
        reverse_proxy backend:8000
    }

    # Metrics (internal only — blocked from external access)
    handle /metrics {
        respond "Forbidden" 403
    }

    # Grafana dashboard
    handle_path /grafana/* {
        reverse_proxy grafana:3000
    }

    # Dozzle log viewer
    handle_path /dozzle/* {
        reverse_proxy dozzle:8080
    }

    # Everything else → frontend
    handle {
        reverse_proxy frontend:3000
    }
}
